<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- 允许外部 App 查询打卡数据 -->
    <permission
        android:name="com.jaye.didadida.permission.READ_DATA"
        android:protectionLevel="normal" />
    <uses-permission android:name="com.jaye.didadida.permission.READ_DATA" />

    <application
        android:name=".App"
        android:allowBackup="true"
        android:icon="@drawable/ic_launcher"
        android:label="滴答滴答"
        android:supportsRtl="true"
        android:theme="@style/Theme.DidaDida">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:theme="@style/Theme.DidaDida">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>

            <!-- Shortcut 动作（只用来接收 shortcut 点击，不需要 filter） -->
            <meta-data
                android:name="android.app.shortcuts"
                android:resource="@xml/shortcuts" />
        </activity>
        <!-- 外部数据查询 Receiver（用于 RikkaHub 等 App 读取打卡数据） -->
        <receiver
            android:name=".bridge.DataQueryReceiver"
            android:exported="true"
            android:permission="com.jaye.didadida.permission.READ_DATA" />

        <!-- 声明 AppDataBridge 协议版本，供插件系统自动发现 -->
        <meta-data
            android:name="app_data_bridge"
            android:value="v1" />
    </application>
</manifest>
