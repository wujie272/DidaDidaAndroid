<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- 允许外部 App 查询打卡数据 -->
    <permission
        android:name="com.jaye.didadida.permission.READ_DATA"
        android:protectionLevel="normal" />
    <uses-permission android:name="com.jaye.didadida.permission.READ_DATA" />

    <application
        android:name=".App"
        android:allowBackup="true"
        android:icon="@drawable/ic_launcher"
        android:label="滴答滴答"
        android:supportsRtl="true"
        android:theme="@style/Theme.DidaDida">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:theme="@style/Theme.DidaDida">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>

            <!-- Shortcut 动作（只用来接收 shortcut 点击，不需要 filter） -->
            <meta-data
                android:name="android.app.shortcuts"
                android:resource="@xml/shortcuts" />
        </activity>
        <!-- 外部数据查询 Provider（用于 RikkaHub 等 App 读取打卡数据） -->
        <provider
            android:name=".bridge.DidaDataProvider"
            android:authorities="com.jaye.didadida.provider"
            android:exported="true"
            android:permission="com.jaye.didadida.permission.READ_DATA">
            <meta-data
                android:name="app_data_bridge"
                android:value="v1" />
        </provider>
    </application>
</manifest>
